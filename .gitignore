# Python build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# pytest cache
.pytest_cache/
.cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data files — raw extractions and processed datasets
# Official committed datasets (Phase 1C and later) are NOT excluded.
# Developer-generated local extractions can be excluded by adding patterns here.
data/metadata/extractions/*.json

# Prevent accidental root-level data commits (data belongs under data/)
/cbrest_*
/proc_*

# Keep directory structure via .gitkeep
!data/raw/coinbase_rest/.gitkeep
!data/processed/.gitkeep
!data/metadata/extractions/.gitkeep

# Log files
logs/*.log
logs/*.jsonl

# Reports — generated outputs should not be committed as source
reports/*.html
reports/*.pdf
reports/*.png

# macOS
.DS_Store

# Secrets / env
.env
*.env
secrets.yaml
